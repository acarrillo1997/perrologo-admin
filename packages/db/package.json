{
  "name": "@perrologo/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/db/src/index.js",
  "types": "dist/db/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/db/src/index.d.ts",
      "default": "./dist/db/src/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@perrologo/domain": "workspace:*",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.41.0",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.4",
    "tsx": "^4.19.3"
  }
}
