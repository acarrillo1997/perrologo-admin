{
  "name": "@perrologo/api",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.1",
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && pnpm --filter @perrologo/domain build && pnpm --filter @perrologo/db build && tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/formbody": "^8.0.2",
    "@perrologo/db": "workspace:*",
    "@perrologo/domain": "workspace:*",
    "ai": "^5.0.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "pino": "^9.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.3",
    "vitest": "^3.0.7"
  }
}
